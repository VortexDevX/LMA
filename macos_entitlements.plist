<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow running in background -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    
    <!-- Network access -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <false/>
    
    <!-- File access -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Home directory access -->
    <key>com.apple.security.files.home-relative-path.read-write</key>
    <array>
        <string>Library/Application Support/LocalMonitorAgent</string>
        <string>Library/Logs/LocalMonitorAgent</string>
        <string>.local/share/LocalMonitorAgent</string>
    </array>
    
    <!-- Allow running scripts/binaries -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <false/>
    
    <!-- Allow reading clipboard NOT needed for this app -->
    <key>com.apple.security.personal-information.photos-library</key>
    <false/>
    
    <!-- Allow microphone NOT needed -->
    <key>com.apple.security.device.microphone</key>
    <false/>
    
    <!-- Allow camera NOT needed -->
    <key>com.apple.security.device.camera</key>
    <false/>
</dict>
</plist>
