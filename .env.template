# ============================================================
# LOCAL MONITORING AGENT � ENVIRONMENT CONFIG
# ============================================================
# Copy this to .env and fill in real values

API_BASE_URL=https://emp-manan.mvlab.cloud
API_KEY=your_api_key_here
# Base64-encoded raw Ed25519 public key used to verify release manifests.
UPDATE_PUBLIC_KEY=replace_with_release_public_key
MAX_UPDATE_SIZE_MB=250

# Collection intervals (seconds)
APP_POLL_INTERVAL=1
NETWORK_POLL_INTERVAL=5
BATCH_SEND_INTERVAL=300
SESSION_UPDATE_INTERVAL=900

# Idle detection threshold (seconds)
IDLE_THRESHOLD=60
SESSION_SPLIT_IDLE=300

# Debug mode
DEBUG=false
LOG_LEVEL=INFO
